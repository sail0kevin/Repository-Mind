{
  "name": "repomind-desktop",
  "version": "0.1.0",
  "description": "Local Windows-first Git repository knowledge assistant with snapshot-bound evidence and traceable analysis.",
  "author": "sail0kevin",
  "repository": {
    "type": "git",
    "url": "https://github.com/sail0kevin/Repository-Mind.git"
  },
  "homepage": "https://github.com/sail0kevin/Repository-Mind",
  "main": "dist-electron/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n renderer,electron -c blue,green \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 && npm run build:electron && cross-env NODE_ENV=development electron .",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron",
    "build": "npm run build:renderer && npm run build:electron",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:packaged": "playwright test --config playwright.config.ts",
    "start": "electron .",
    "build:backend": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/build_backend.ps1 -PythonCommand python",
    "smoke:backend": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/smoke_backend.ps1 -ExePath ../../backend-dist/repomind-backend.exe",
    "package:dir": "npm run build && electron-builder --config electron-builder.yml --win dir",
    "package:release": "npm run build && electron-builder --config electron-builder.yml --win nsis portable",
    "package": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/package_windows.ps1 -Release"
  },
  "engines": {
    "node": ">=20 <21",
    "npm": ">=10 <11"
  },
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^32.2.0",
    "electron-builder": "^24.13.3",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.9",
    "vitest": "^2.1.9",
    "wait-on": "^8.0.1"
  }
}
